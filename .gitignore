# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Distil local database — never commit personal data
/data/distil.db
/data/distil.db-shm
/data/distil.db-wal

# Authenticated publisher session data (cookies, storage state) — never commit
data/publisher-sessions/

# Environment variables — copy .env.example to .env.local, never commit .env.local
.env.local

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.pptx

# Claude / AI agent config (developer-specific)
.claude/

# Eval results (generated)
evals/results/*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
